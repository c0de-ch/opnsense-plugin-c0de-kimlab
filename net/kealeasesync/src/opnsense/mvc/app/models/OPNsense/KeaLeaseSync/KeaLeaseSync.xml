<model>
    <mount>//OPNsense/KeaLeaseSync</mount>
    <version>1.0.0</version>
    <description>Kea Lease DNS Sync settings</description>
    <items>
        <general>
        <enabled type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </enabled>
        <directDomain type="TextField">
            <Required>N</Required>
            <Mask>/^([a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}$/</Mask>
            <ValidationMessage>Enter a valid domain name</ValidationMessage>
        </directDomain>
        <proxyDomains type="TextField">
            <Required>N</Required>
            <Mask>/^(([a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}(\s+|$))*$/</Mask>
            <ValidationMessage>Enter valid domain names separated by spaces</ValidationMessage>
        </proxyDomains>
        <proxyIpv4 type="NetworkField">
            <Required>N</Required>
            <NetMaskAllowed>N</NetMaskAllowed>
            <AddressFamily>IPv4</AddressFamily>
        </proxyIpv4>
        <proxyIpv6 type="NetworkField">
            <Required>N</Required>
            <NetMaskAllowed>N</NetMaskAllowed>
            <AddressFamily>IPv6</AddressFamily>
        </proxyIpv6>
        <lease4File type="TextField">
            <Default>/var/db/kea/kea-leases4.csv</Default>
            <Required>Y</Required>
            <Mask>/^\/[^\s]+$/</Mask>
            <ValidationMessage>Enter a valid absolute file path</ValidationMessage>
        </lease4File>
        <lease6File type="TextField">
            <Default>/var/db/kea/kea-leases6.csv</Default>
            <Required>Y</Required>
            <Mask>/^\/[^\s]+$/</Mask>
            <ValidationMessage>Enter a valid absolute file path</ValidationMessage>
        </lease6File>
        <keaConf type="TextField">
            <Default>/usr/local/etc/kea/kea-dhcp4.conf</Default>
            <Required>Y</Required>
            <Mask>/^\/[^\s]+$/</Mask>
            <ValidationMessage>Enter a valid absolute file path</ValidationMessage>
        </keaConf>
        <ttl type="IntegerField">
            <Default>300</Default>
            <Required>Y</Required>
            <MinimumValue>60</MinimumValue>
            <MaximumValue>86400</MaximumValue>
            <ValidationMessage>TTL must be between 60 and 86400 seconds</ValidationMessage>
        </ttl>
        <scanInterval type="OptionField">
            <Default>i1</Default>
            <Required>Y</Required>
            <OptionValues>
                <i1>1 minute</i1>
                <i2>2 minutes</i2>
                <i5>5 minutes</i5>
                <i10>10 minutes</i10>
                <i15>15 minutes</i15>
                <i30>30 minutes</i30>
                <i60>60 minutes</i60>
            </OptionValues>
        </scanInterval>
        <peerEnabled type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </peerEnabled>
        <peerUrl type="TextField">
            <Required>N</Required>
            <Mask>/^https?:\/\/[^\s]+$/</Mask>
            <ValidationMessage>Enter a valid URL (e.g. https://firewall.example.com)</ValidationMessage>
        </peerUrl>
        <peerApiKey type="TextField">
            <Required>N</Required>
        </peerApiKey>
        <peerApiSecret type="TextField">
            <Required>N</Required>
        </peerApiSecret>
        </general>
    </items>
</model>
